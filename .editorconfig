# EditorConfig (https://editorconfig.org) — pinned to match the
# .prettierrc / .prettierignore + the existing tab-indented style of
# this repo. Prettier still has the final say at format time; this file
# just gives editors that don't run Prettier-on-save the right defaults.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 2

[*.{yml,yaml,md}]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4
